                {
                    "label": "A",
                    "content": "$f'(x_0) = \\lim_{\\Delta x \\to 0} \\frac{f(x_0 + \\Delta x) + f(x_0)}{\\Delta x}$",
                    "is_correct": false
                },
                {
                    "label": "B",
                    "content": "$f'(x_0) = \\lim_{\\Delta x \\to 0} \\frac{f(x_0 + \\Delta x) - f(x_0)}{\\Delta x}$",
