                },
                {
                    "label": "C",
                    "content": "$f'(x_0) = \\lim_{\\Delta x \\to \\infty} \\frac{f(x_0 + \\Delta x) - f(x_0)}{\\Delta x}$",
                    "is_correct": false
                },
                {
                    "label": "D",
                    "content": "$f'(x_0) = f(x_0 + 1) - f(x_0)$",
                    "is_correct": false
                }
            ]
